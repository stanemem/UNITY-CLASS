<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GANDANAPP.MainPage"
             BackgroundColor="#111827">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- ========== 상단 공통 헤더 ========== -->
            <Border BackgroundColor="#1F2937"
                    StrokeThickness="0"
                    Padding="16"
                    StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Spacing="12">
                    <Label Text="일본어 암기 앱"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />

                    <Picker x:Name="ModePicker"
                            Title="모드 선택"
                            SelectedIndexChanged="OnModeChanged"
                            TextColor="White"
                            BackgroundColor="#374151">
                        <Picker.Items>
                            <x:String>한자 모드</x:String>
                            <x:String>문법 모드</x:String>
                            <x:String>문법패턴 모드</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <!-- ========================================== -->
            <!-- 한자 모드 -->
            <!-- ========================================== -->
            <ContentView x:Name="KanjiModeView">
                <VerticalStackLayout Spacing="16">

                    <Border BackgroundColor="#1F2937"
                            StrokeThickness="0"
                            Padding="16"
                            StrokeShape="RoundRectangle 20">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="ProgressLabel"
                                   Text="진행: 0 / 0"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center" />

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">
                                <HorizontalStackLayout Grid.Column="0"
                                                       Spacing="8"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center">
                                    <Label Text="후리가나"
                                           TextColor="White"
                                           VerticalTextAlignment="Center" />
                                    <Switch x:Name="FuriganaSwitch"
                                            Toggled="OnFuriganaToggled" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Column="1"
                                                       Spacing="8"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center">
                                    <Label Text="순차 모드"
                                           TextColor="White"
                                           VerticalTextAlignment="Center" />
                                    <Switch x:Name="SequentialSwitch"
                                            Toggled="OnSequentialToggled" />
                                </HorizontalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#1F2937"
                            StrokeThickness="0"
                            Padding="24"
                            MinimumHeightRequest="320"
                            StrokeShape="RoundRectangle 24">
                        <VerticalStackLayout VerticalOptions="Center"
                                             Spacing="18">
                            <Label Text="후리가나"
                                   FontSize="16"
                                   TextColor="#9CA3AF"
                                   HorizontalTextAlignment="Center" />
                            <Label x:Name="FuriganaLabel"
                                   Text=""
                                   FontSize="26"
                                   TextColor="#FCD34D"
                                   HorizontalTextAlignment="Center"
                                   IsVisible="False" />
                            <Label Text="한국어 뜻"
                                   FontSize="18"
                                   TextColor="#9CA3AF"
                                   HorizontalTextAlignment="Center" />
                            <Label x:Name="KoreanLabel"
                                   Text=""
                                   FontSize="40"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="일본어"
                                   FontSize="16"
                                   TextColor="#9CA3AF"
                                   HorizontalTextAlignment="Center" />
                            <Label x:Name="JapaneseLabel"
                                   Text=""
                                   FontSize="34"
                                   TextColor="#93C5FD"
                                   HorizontalTextAlignment="Center"
                                   IsVisible="False" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="10">
                        <Button Grid.Row="0" Grid.Column="0"
                                Text="이전" Clicked="OnPrevClicked" />
                        <Button Grid.Row="0" Grid.Column="1"
                                Text="정답 보기" Clicked="OnShowAnswerClicked" />
                        <Button Grid.Row="0" Grid.Column="2"
                                Text="다음" Clicked="OnNextClicked" />
                        <Button x:Name="FavoriteButton"
                                Grid.Row="1" Grid.Column="0"
                                Text="☆ 즐겨찾기" Clicked="OnFavoriteClicked" />
                        <Button x:Name="FavoritesToggleButton"
                                Grid.Row="1" Grid.Column="1"
                                Text="즐겨찾기 목록 보기" Clicked="OnToggleFavoritesListClicked" />
                        <Button x:Name="KanjiListToggleButton"
                                Grid.Row="1" Grid.Column="2"
                                Text="한자 목차 보기" Clicked="OnToggleKanjiListClicked" />
                    </Grid>

                    <!-- 즐겨찾기 목록 -->
                    <Border x:Name="FavoritesPanel"
                            BackgroundColor="#1F2937" StrokeThickness="0"
                            Padding="16" StrokeShape="RoundRectangle 20"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="FavoritesSummaryLabel"
                                   Text="즐겨찾기: 0개" FontSize="18"
                                   FontAttributes="Bold" TextColor="White" />
                            <Label x:Name="EmptyFavoritesLabel"
                                   Text="아직 즐겨찾기한 단어가 없음"
                                   TextColor="#9CA3AF" IsVisible="False" />
                            <CollectionView x:Name="FavoritesCollectionView"
                                            SelectionMode="Single"
                                            SelectionChanged="OnFavoriteSelected"
                                            MaximumHeightRequest="320">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#111827" StrokeThickness="0"
                                                Padding="12" Margin="0,0,0,8"
                                                StrokeShape="RoundRectangle 14">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Korean}" FontSize="18"
                                                       FontAttributes="Bold" TextColor="White" />
                                                <HorizontalStackLayout Spacing="10">
                                                    <Label Text="{Binding Japanese}" FontSize="18" TextColor="#93C5FD" />
                                                    <Label Text="{Binding Furigana}" FontSize="15" TextColor="#FCD34D" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <!-- 한자 전체 목차 -->
                    <Border x:Name="KanjiListPanel"
                            BackgroundColor="#1F2937" StrokeThickness="0"
                            Padding="16" StrokeShape="RoundRectangle 20"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="KanjiListSummaryLabel"
                                   Text="한자 목차: 0개" FontSize="18"
                                   FontAttributes="Bold" TextColor="White" />
                            <CollectionView x:Name="KanjiListCollectionView"
                                            SelectionMode="Single"
                                            SelectionChanged="OnKanjiListSelected"
                                            MaximumHeightRequest="420">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#111827" StrokeThickness="0"
                                                Padding="12" Margin="0,0,0,8"
                                                StrokeShape="RoundRectangle 14">
                                            <HorizontalStackLayout Spacing="10">
                                                <Label Text="{Binding IndexDisplay}" FontSize="14"
                                                       TextColor="#6B7280" VerticalTextAlignment="Center" WidthRequest="36" />
                                                <Label Text="{Binding FavStar}" FontSize="16"
                                                       TextColor="#FCD34D" VerticalTextAlignment="Center" WidthRequest="24" />
                                                <Label Text="{Binding Korean}" FontSize="17"
                                                       FontAttributes="Bold" TextColor="White" VerticalTextAlignment="Center" />
                                                <Label Text="{Binding Japanese}" FontSize="17"
                                                       TextColor="#93C5FD" VerticalTextAlignment="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ContentView>

            <!-- ========================================== -->
            <!-- 문법 모드 (전자책 스타일) -->
            <!-- ========================================== -->
            <ContentView x:Name="GrammarModeView"
                         IsVisible="False">
                <VerticalStackLayout Spacing="16">

                    <Border BackgroundColor="#1F2937" StrokeThickness="0"
                            Padding="16" StrokeShape="RoundRectangle 20">
                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="GrammarProgressLabel"
                                   Text="문법: 0 / 0" FontSize="18"
                                   FontAttributes="Bold" TextColor="White"
                                   HorizontalTextAlignment="Center" />
                            <ProgressBar x:Name="GrammarProgressBar"
                                         Progress="0" ProgressColor="#60A5FA"
                                         BackgroundColor="#374151" HeightRequest="6" />
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#1F2937" StrokeThickness="0"
                            Padding="28" MinimumHeightRequest="380"
                            StrokeShape="RoundRectangle 24">
                        <VerticalStackLayout Spacing="16">
                            <Border BackgroundColor="#374151" StrokeThickness="0"
                                    Padding="8,4" HorizontalOptions="Start"
                                    StrokeShape="RoundRectangle 8">
                                <Label x:Name="GrammarCategoryLabel"
                                       Text="카테고리" FontSize="13" TextColor="#FCD34D" />
                            </Border>
                            <Label x:Name="GrammarTitleLabel"
                                   Text="제목" FontSize="26" FontAttributes="Bold" TextColor="White" />
                            <Label x:Name="GrammarSummaryLabel"
                                   Text="요약" FontSize="16" TextColor="#93C5FD" FontAttributes="Italic" />
                            <BoxView HeightRequest="1" Color="#374151" Margin="0,4" />
                            <Label x:Name="GrammarContentLabel"
                                   Text="설명" FontSize="16" TextColor="#E5E7EB"
                                   LineBreakMode="WordWrap" LineHeight="1.4" />
                            <Label x:Name="GrammarPageLabel"
                                   Text="1 / 1" FontSize="13" TextColor="#6B7280"
                                   HorizontalTextAlignment="End" Margin="0,8,0,0" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                          ColumnSpacing="10" RowSpacing="10">
                        <Button Grid.Row="0" Grid.Column="0"
                                Text="이전" Clicked="OnGrammarPrevClicked" />
                        <Button Grid.Row="0" Grid.Column="1"
                                Text="다음" Clicked="OnGrammarNextClicked" />
                        <Button x:Name="GrammarFavoriteButton"
                                Grid.Row="1" Grid.Column="0"
                                Text="☆ 문법 즐겨찾기" Clicked="OnGrammarFavoriteClicked" />
                        <Button x:Name="GrammarListToggleButton"
                                Grid.Row="1" Grid.Column="1"
                                Text="문법 목록 보기" Clicked="OnToggleGrammarListClicked" />
                    </Grid>

                    <Border x:Name="GrammarListPanel"
                            BackgroundColor="#1F2937" StrokeThickness="0"
                            Padding="16" StrokeShape="RoundRectangle 20"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="GrammarListSummaryLabel"
                                   Text="문법 목록" FontSize="18"
                                   FontAttributes="Bold" TextColor="White" />
                            <CollectionView x:Name="GrammarCollectionView"
                                            SelectionMode="Single"
                                            SelectionChanged="OnGrammarSelected"
                                            MaximumHeightRequest="480">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#111827" StrokeThickness="0"
                                                Padding="12" Margin="0,0,0,8"
                                                StrokeShape="RoundRectangle 14">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <Label Grid.Column="0" Text="{Binding IndexDisplay}"
                                                       FontSize="13" TextColor="#6B7280"
                                                       VerticalTextAlignment="Center" WidthRequest="36" />
                                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                                    <Label Text="{Binding TitleDisplay}" FontSize="17"
                                                           FontAttributes="Bold" TextColor="White" />
                                                    <Label Text="{Binding Subtitle}" FontSize="14"
                                                           TextColor="#9CA3AF" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ContentView>

            <!-- ========================================== -->
            <!-- 문법패턴 모드 (강독 패턴 암기용) -->
            <!-- ========================================== -->
            <ContentView x:Name="PatternModeView"
                         IsVisible="False">
                <VerticalStackLayout Spacing="16">

                    <Border BackgroundColor="#1F2937" StrokeThickness="0"
                            Padding="16" StrokeShape="RoundRectangle 20">
                        <VerticalStackLayout Spacing="8">
                            <Label x:Name="PatternProgressLabel"
                                   Text="패턴: 0 / 0" FontSize="18"
                                   FontAttributes="Bold" TextColor="White"
                                   HorizontalTextAlignment="Center" />
                            <ProgressBar x:Name="PatternProgressBar"
                                         Progress="0" ProgressColor="#34D399"
                                         BackgroundColor="#374151" HeightRequest="6" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- 패턴 카드 -->
                    <Border BackgroundColor="#1F2937" StrokeThickness="0"
                            Padding="24" MinimumHeightRequest="420"
                            StrokeShape="RoundRectangle 24">
                        <VerticalStackLayout Spacing="14">

                            <Border BackgroundColor="#065F46" StrokeThickness="0"
                                    Padding="10,5" HorizontalOptions="Start"
                                    StrokeShape="RoundRectangle 8">
                                <Label x:Name="PatternPartLabel"
                                       Text="Part 01" FontSize="13"
                                       FontAttributes="Bold" TextColor="#6EE7B7" />
                            </Border>

                            <Label x:Name="PatternNameLabel"
                                   Text="～ている" FontSize="28"
                                   FontAttributes="Bold" TextColor="White" />

                            <Label x:Name="PatternMeaningLabel"
                                   Text="~하고 있다" FontSize="18"
                                   TextColor="#34D399" />

                            <BoxView HeightRequest="1" Color="#374151" Margin="0,2" />

                            <Label Text="접속 형태" FontSize="13" TextColor="#9CA3AF" />
                            <Label x:Name="PatternConnectionLabel"
                                   Text="동사 て형 + いる" FontSize="16"
                                   TextColor="#FCD34D" FontAttributes="Bold" />

                            <BoxView HeightRequest="1" Color="#374151" Margin="0,2" />

                            <Label Text="예문" FontSize="13" TextColor="#9CA3AF" />
                            <Label x:Name="PatternExampleLabel"
                                   Text="" FontSize="16" TextColor="#E5E7EB"
                                   LineBreakMode="WordWrap" LineHeight="1.4" />

                            <Label x:Name="PatternTranslationLabel"
                                   Text="" FontSize="15" TextColor="#93C5FD"
                                   LineBreakMode="WordWrap" />

                            <BoxView HeightRequest="1" Color="#374151" Margin="0,2" />

                            <Label Text="포인트" FontSize="13" TextColor="#9CA3AF" />
                            <Label x:Name="PatternPointLabel"
                                   Text="" FontSize="15" TextColor="#F9A8D4"
                                   LineBreakMode="WordWrap" LineHeight="1.3" />

                            <Label x:Name="PatternPageLabel"
                                   Text="1 / 16" FontSize="13" TextColor="#6B7280"
                                   HorizontalTextAlignment="End" Margin="0,6,0,0" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                          ColumnSpacing="10" RowSpacing="10">
                        <Button Grid.Row="0" Grid.Column="0"
                                Text="이전" Clicked="OnPatternPrevClicked" />
                        <Button Grid.Row="0" Grid.Column="1"
                                Text="다음" Clicked="OnPatternNextClicked" />
                        <Button x:Name="PatternFavoriteButton"
                                Grid.Row="1" Grid.Column="0"
                                Text="☆ 패턴 즐겨찾기" Clicked="OnPatternFavoriteClicked" />
                        <Button x:Name="PatternListToggleButton"
                                Grid.Row="1" Grid.Column="1"
                                Text="패턴 목록 보기" Clicked="OnTogglePatternListClicked" />
                    </Grid>

                    <Border x:Name="PatternListPanel"
                            BackgroundColor="#1F2937" StrokeThickness="0"
                            Padding="16" StrokeShape="RoundRectangle 20"
                            IsVisible="False">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="PatternListSummaryLabel"
                                   Text="패턴 목록" FontSize="18"
                                   FontAttributes="Bold" TextColor="White" />
                            <CollectionView x:Name="PatternCollectionView"
                                            SelectionMode="Single"
                                            SelectionChanged="OnPatternSelected"
                                            MaximumHeightRequest="480">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#111827" StrokeThickness="0"
                                                Padding="12" Margin="0,0,0,8"
                                                StrokeShape="RoundRectangle 14">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <Label Grid.Column="0" Text="{Binding IndexDisplay}"
                                                       FontSize="13" TextColor="#6B7280"
                                                       VerticalTextAlignment="Center" WidthRequest="36" />
                                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                                    <Label Text="{Binding TitleDisplay}" FontSize="17"
                                                           FontAttributes="Bold" TextColor="White" />
                                                    <Label Text="{Binding Subtitle}" FontSize="14"
                                                           TextColor="#9CA3AF" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ContentView>

            <!-- 앱 정보 / 저작권 -->
            <Button Text="앱 정보 / 저작권"
                    Clicked="OnAboutClicked" />

            <Label Text="© 2026  유한대 게임콘텐츠과 박찬솔. All Rights Reserved."
                   FontSize="12"
                   TextColor="#9CA3AF"
                   HorizontalTextAlignment="Center"
                   Margin="0,6,0,20" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
